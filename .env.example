# Copy to .env and fill in. .env is git-ignored.

# --- Required ---------------------------------------------------------------
# Anthropic API key used by BOTH kagent agents and the OpenClaw assistant.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (defaults shown) ----------------------------------------------
# Kubeconfig context to target. Must match your AKS cluster's context.
# KUBE_CONTEXT=claw

# Namespaces
# OPENCLAW_NAMESPACE=openclaw
# KAGENT_NAMESPACE=kagent
# CERT_MANAGER_NAMESPACE=cert-manager
# ENVOY_NAMESPACE=envoy-gateway-system

# OpenClaw model as "<provider>/<model-id>"
# OPENCLAW_MODEL=anthropic/claude-sonnet-4-5

# cert-manager chart version
# CERT_MANAGER_VERSION=v1.16.2
